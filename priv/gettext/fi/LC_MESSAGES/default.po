"This only affects the user interface. Your analytics data will remain intact."
msgstr ""
"Tämä vaikuttaa vain käyttöliittymään. Analytiikkatietosi säilyvät ennallaan."

msgid "Country block list"
msgstr "Estetyt maat"

msgid "Reject incoming traffic from specific countries."
msgstr "Hylkää tietyistä maista tuleva liikenne."

msgid "Block a country"
msgstr "Estä maa"

msgid "Add country"
msgstr "Lisää maa"

msgid "Maximum number of countries reached"
msgstr "Maiden enimmäismäärä saavutettu"

msgid ""
"You have reached the maximum of %{count} blocked countries. Remove one "
"before adding another."
msgstr ""
"Estettyjen maiden enimmäismäärä %{count} on saavutettu. Poista yksi ennen "
"uuden lisäämistä."

